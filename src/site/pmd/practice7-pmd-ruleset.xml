<?xml version="1.0" encoding="UTF-8"?>
<ruleset
    name="Practice 7 PMD Metrics Ruleset"
    xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
  <description>
    Customized PMD ruleset for Practice 7. It keeps only the rules related to
    size, complexity, coupling, and cohesion metrics discussed in class.
  </description>

  <!-- LoC: use NCSS as the closest PMD size metric. -->
  <rule ref="category/java/design.xml/NcssCount" />

  <!-- CC: direct cyclomatic complexity check. -->
  <rule ref="category/java/design.xml/CyclomaticComplexity" />

  <!-- CBO: direct coupling between objects check. -->
  <rule ref="category/java/design.xml/CouplingBetweenObjects" />

  <!-- WMC: TooManyMethods is the closest class-level method-weight proxy. -->
  <rule ref="category/java/design.xml/TooManyMethods" />

  <!-- LCOM: GodClass flags classes with low cohesion (low TCC). -->
  <rule ref="category/java/design.xml/GodClass" />
</ruleset>
